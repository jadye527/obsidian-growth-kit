{
  "description": "Copy these jobs into your ~/.openclaw/cron/jobs.json to automate X growth",
  "jobs": [
    {
      "id": "x-autonomous-post",
      "name": "x-autonomous-post",
      "description": "Twice-daily autonomous posting: generate a meme, publish, self-reply, and handle mentions",
      "enabled": true,
      "schedule": {
        "kind": "cron",
        "expr": "0 9,18 * * *",
        "tz": "America/New_York"
      },
      "sessionTarget": "isolated",
      "wakeMode": "next-heartbeat",
      "payload": {
        "kind": "agentTurn",
        "message": "xcron autonomous-post",
        "thinking": "low"
      }
    },
    {
      "id": "x-morning-growth",
      "name": "x-morning-growth",
      "description": "Morning X growth: post content, engage with niche accounts, implement one new growth tactic",
      "enabled": true,
      "schedule": {
        "kind": "cron",
        "expr": "0 8 * * *",
        "tz": "America/New_York"
      },
      "sessionTarget": "isolated",
      "wakeMode": "next-heartbeat",
      "payload": {
        "kind": "agentTurn",
        "message": "xcron morning-growth",
        "thinking": "low"
      }
    },
    {
      "id": "x-content-scout",
      "name": "x-content-scout",
      "description": "Content scout: find high-engagement tweets, like viral content, queue reactive posts",
      "enabled": true,
      "schedule": {
        "kind": "cron",
        "expr": "23 9,12,15,18 * * *",
        "tz": "America/New_York"
      },
      "sessionTarget": "isolated",
      "wakeMode": "next-heartbeat",
      "payload": {
        "kind": "agentTurn",
        "message": "xcron content-scout",
        "thinking": "low"
      }
    },
    {
      "id": "x-nightly-review",
      "name": "x-nightly-review",
      "description": "Nightly analytics review and strategy adjustment",
      "enabled": true,
      "schedule": {
        "kind": "cron",
        "expr": "0 22 * * *",
        "tz": "America/New_York"
      },
      "sessionTarget": "isolated",
      "wakeMode": "next-heartbeat",
      "payload": {
        "kind": "agentTurn",
        "message": "xcron nightly-review",
        "thinking": "low"
      }
    },
    {
      "id": "x-analytics-snapshot",
      "name": "x-analytics-snapshot",
      "description": "Take X analytics snapshot every 4 hours for tracking",
      "enabled": true,
      "schedule": {
        "kind": "cron",
        "expr": "0 8,12,16,20 * * *",
        "tz": "America/New_York"
      },
      "sessionTarget": "isolated",
      "wakeMode": "next-heartbeat",
      "payload": {
        "kind": "agentTurn",
        "message": "xcron analytics-snapshot",
        "thinking": "low"
      }
    }
  ]
}
