#!/usr/bin/env python3
"""xmemory — maintain shared memory notes."""
import os
import subprocess
import sys
from urllib import parse

HELP_TEXT = """xmemory — Shared memory note helper

Usage:
  xmemory ralph-session-log [options] <work-item> [<work-item> ...]
  xmemory memory-search [options]
  xmemory --help

Commands:
  ralph-session-log               Append or update Ralph's dated session log
  memory-search                   Fetch a memory search response and save it

Options:
  --memory-file PATH             Target note path. Defaults to
                                 $OPENCLAW_RALPH_MEMORY_FILE or
                                 ~/.openclaw/workspace-obsidian/memory/ralph.md
  --date YYYY-MM-DD              Session date. Defaults to today's local date.
  --url URL                      Memory API URL. Defaults to
                                 $OPENCLAW_MEMORY_API_URL or
                                 http://127.0.0.1:3000/api/memory
  --api-key KEY                  Memory API key. Defaults to
                                 $OPENCLAW_MEMORY_API_KEY
  --query TEXT                   Memory search query. Required for
                                 memory-search.
  --output PATH                  Output file for memory-search. Required.

Examples:
  xmemory ralph-session-log "Added pytest coverage"
  xmemory ralph-session-log --memory-file ./memory/ralph.md \\
    "Implemented xmemory" "Ran pytest and Ruff"
  xmemory memory-search --api-key secret --query ralph \\
    --output /tmp/ralph-memory-test.json
"""

SESSION_HEADER = "## Ralph's Session Log"


def print_help():
    """Print the CLI help text."""
    print(HELP_TEXT)


def exit_error(message):
    """Print an actionable error message and exit."""
    print(message, file=sys.stderr)
    raise SystemExit(1)


def expand_memory_file(path=None):
    """Resolve the Ralph memory note path."""
    if path:
        return os.path.expanduser(path)

    configured = os.environ.get("OPENCLAW_RALPH_MEMORY_FILE")
    if configured:
        return os.path.expanduser(configured)

    return os.path.expanduser("~/.openclaw/workspace-obsidian/memory/ralph.md")


def expand_output_file(path):
    """Resolve an output file path."""
    return os.path.expanduser(path)


def default_memory_api_url():
    """Return the default memory API URL."""
    configured = os.environ.get("OPENCLAW_MEMORY_API_URL")
    if configured:
        return configured
    return "http://127.0.0.1:3000/api/memory"


def default_memory_api_key():
    """Return the configured memory API key, if any."""
    return os.environ.get("OPENCLAW_MEMORY_API_KEY")


def today_local_date():
    """Return today's local date in ISO format."""
    from datetime import date

    return date.today().isoformat()


def format_session_entry(session_date, work_items):
    """Render one dated Ralph session log entry."""
    lines = [f"### {session_date}"]
    lines.extend(f"- {item}" for item in work_items)
    return "\n".join(lines)


def split_entry_blocks(section_body):
    """Split a session-log section into dated entry blocks."""
    stripped = section_body.strip()
    if not stripped:
        return []
    return stripped.split("\n\n")


def upsert_session_log(note_text, session_date, work_items):
    """Insert or replace the Ralph session log entry for a date."""
    entry = format_session_entry(session_date, work_items)
    header = SESSION_HEADER

    if header not in note_text:
        base = note_text.rstrip()
        if base:
            return f"{base}\n\n{header}\n{entry}\n"
        return f"{header}\n{entry}\n"

    before, after = note_text.split(header, maxsplit=1)
    section_body = after.lstrip("\n")
    section_body = section_body.rstrip()
    blocks = split_entry_blocks(section_body)
    date_header = f"### {session_date}"
    updated = False
    new_blocks = []

    for block in blocks:
        if block.startswith(date_header):
            new_blocks.append(entry)
            updated = True
            continue
        new_blocks.append(block)

    if not updated:
        new_blocks.append(entry)

    rebuilt = "\n\n".join(block for block in new_blocks if block.strip())
    return f"{before.rstrip()}\n\n{header}\n{rebuilt}\n"


def update_ralph_session_log(memory_file, session_date, work_items):
    """Write Ralph's session log entry to a memory note."""
    note_text = ""
    if os.path.exists(memory_file):
        with open(memory_file, encoding="utf-8") as handle:
            note_text = handle.read()

    updated = upsert_session_log(note_text, session_date, work_items)
    directory = os.path.dirname(memory_file)
    if directory:
        os.makedirs(directory, exist_ok=True)
    with open(memory_file, "w", encoding="utf-8") as handle:
        handle.write(updated)


def parse_ralph_session_args(args):
    """Parse arguments for the Ralph session log command."""
    memory_file = None
    session_date = today_local_date()
    work_items = []
    index = 0

    while index < len(args):
        arg = args[index]
        if arg == "--memory-file":
            if index + 1 >= len(args):
                exit_error("Missing value for --memory-file")
            memory_file = args[index + 1]
            index += 2
            continue
        if arg == "--date":
            if index + 1 >= len(args):
                exit_error("Missing value for --date")
            session_date = args[index + 1]
            index += 2
            continue
        if arg.startswith("--"):
            exit_error(f"Unknown option: {arg}")
        work_items.extend(args[index:])
        break

    if not work_items:
        exit_error("Usage: xmemory ralph-session-log [options] <work-item> [...]")

    return expand_memory_file(memory_file), session_date, work_items


def parse_memory_search_args(args):
    """Parse arguments for the memory-search command."""
    api_key = default_memory_api_key()
    output_file = None
    query = None
    url = default_memory_api_url()
    index = 0

    while index < len(args):
        arg = args[index]
        if arg == "--api-key":
            if index + 1 >= len(args):
                exit_error("Missing value for --api-key")
            api_key = args[index + 1]
            index += 2
            continue
        if arg == "--output":
            if index + 1 >= len(args):
                exit_error("Missing value for --output")
            output_file = args[index + 1]
            index += 2
            continue
        if arg == "--query":
            if index + 1 >= len(args):
                exit_error("Missing value for --query")
            query = args[index + 1]
            index += 2
            continue
        if arg == "--url":
            if index + 1 >= len(args):
                exit_error("Missing value for --url")
            url = args[index + 1]
            index += 2
            continue
        exit_error(f"Unknown option: {arg}")

    if not query:
        exit_error("Missing required option: --query")
    if not output_file:
        exit_error("Missing required option: --output")
    if not api_key:
        exit_error("Missing required option: --api-key")

    return url, api_key, query, expand_output_file(output_file)


def build_memory_search_url(url, query):
    """Build the memory search URL with query parameters."""
    encoded_query = parse.urlencode({"action": "search", "query": query})
    separator = "&" if "?" in url else "?"
    return f"{url}{separator}{encoded_query}"


def fetch_memory_search(url, api_key, query):
    """Fetch a memory search response from the configured API."""
    search_url = build_memory_search_url(url, query)
    completed = subprocess.run(
        [
            "curl",
            "-sS",
            search_url,
            "-H",
            f"x-api-key: {api_key}",
        ],
        capture_output=True,
        check=False,
    )
    if completed.returncode != 0:
        exit_error(completed.stderr.decode("utf-8", errors="replace").strip())
    return completed.stdout


def write_output_file(output_file, content):
    """Write fetched content to an output file."""
    directory = os.path.dirname(output_file)
    if directory:
        os.makedirs(directory, exist_ok=True)
    with open(output_file, "wb") as handle:
        handle.write(content)


def main():
    """Run the xmemory CLI."""
    args = sys.argv[1:]
    if not args or args[0] in {"--help", "-h"}:
        print_help()
        return

    command = args[0]
    if command == "ralph-session-log":
        memory_file, session_date, work_items = parse_ralph_session_args(args[1:])
        update_ralph_session_log(memory_file, session_date, work_items)
        print(f"Updated Ralph session log in {memory_file}")
        return
    if command == "memory-search":
        url, api_key, query, output_file = parse_memory_search_args(args[1:])
        content = fetch_memory_search(url, api_key, query)
        write_output_file(output_file, content)
        print(f"Saved memory search results to {output_file}")
        return

    exit_error(f"Unknown command: {command}")


if __name__ == "__main__":
    main()
