#!/usr/bin/env python3
"""xgrowth — X Growth Engine for @YourHandle."""
import json
import os
import subprocess
import sys
from datetime import datetime, timezone

DATA_DIR = os.path.expanduser("~/.config/x-api")
GROWTH_FILE = os.path.join(DATA_DIR, "growth-tracker.json")
STRATEGY_FILE = os.path.join(DATA_DIR, "strategy-log.json")

HELP_TEXT = """xgrowth — X Growth Engine

Usage:
  xgrowth <command> [args]
  xgrowth --help

Commands:
  track                            Analyze all posts and categorize performance
  report                           Full growth report with recommendations
  strategy                         Show current strategy and change history
  log-strategy <name> <desc> [m]   Log a new strategy with optional metrics
  new-strategy                     Show today's suggested tactic ideas
  leaderboard                      Show accounts we should study/emulate

Examples:
  xgrowth track
  xgrowth report
  xgrowth strategy
  xgrowth log-strategy "Thread hooks" "Lead with stronger opening claims"
  xgrowth leaderboard
"""


def print_help():
    print(HELP_TEXT)

def load_json(path, default=None):
    if os.path.exists(path):
        with open(path) as f:
            return json.load(f)
    return default or {}

def save_json(path, data):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w") as f:
        json.dump(data, f, indent=2)

def run_cmd(cmd):
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
        return r.stdout
    except:
        return ""

def get_our_tweets():
    """Fetch our recent tweets with metrics."""
    import re
    output = run_cmd(["xpost", "user-tweets", "YourHandle"])
    tweets = []
    lines = output.strip().split("\n")
    i = 0
    while i < len(lines):
        line = lines[i].strip()
        if "· 2026-" in line or "· 2025-" in line:
            date = line.strip().lstrip("· ").strip()
            text_lines = []
            i += 1
            likes = rts = replies = 0
            tweet_id = ""
            while i < len(lines):
                l = lines[i].strip()
                if l.startswith("♥"):
                    m = re.findall(r'♥\s*(\d+)', l)
                    likes = int(m[0]) if m else 0
                    m = re.findall(r'🔁\s*(\d+)', l)
                    rts = int(m[0]) if m else 0
                    m = re.findall(r'💬\s*(\d+)', l)
                    replies = int(m[0]) if m else 0
                    m = re.findall(r'id:(\d+)', l)
                    tweet_id = m[0] if m else ""
                    i += 1
                    break
                elif l == "---":
                    i += 1
                    break
                else:
                    text_lines.append(l)
                    i += 1
            text = "\n".join(text_lines)
            # Categorize post type
            post_type = categorize(text)
            engagement = likes + rts * 3 + replies * 5
            tweets.append({
                "id": tweet_id, "date": date, "text": text,
                "likes": likes, "retweets": rts, "replies": replies,
                "engagement": engagement, "type": post_type,
                "is_reply": text.startswith("@"),
            })
        else:
            i += 1
    return tweets

def categorize(text):
    """Categorize a post by content type."""
    t = text.lower()
    if any(w in t for w in ["😂", "🫠", "stages of", "accidentally", "innovation"]):
        return "humor"
    if any(w in t for w in ["day 1", "week 1", "honest numbers", "p&l", "win rate"]):
        return "build-in-public"
    if any(w in t for w in ["tip:", "lesson:", "edge", "strategy", "the gap between"]):
        return "value"
    if any(w in t for w in ["→", "✅", "📊", "results"]):
        return "update"
    if text.startswith("@"):
        return "reply"
    return "general"

def track_performance():
    """Analyze all posts and track what's working."""
    tweets = get_our_tweets()
    if not tweets:
        print("No tweets to analyze.")
        return

    # Group by type
    by_type = {}
    for t in tweets:
        tp = t["type"]
        if tp not in by_type:
            by_type[tp] = {"count": 0, "total_engagement": 0, "total_likes": 0,
                           "total_replies": 0, "total_rts": 0, "best": None}
        by_type[tp]["count"] += 1
        by_type[tp]["total_engagement"] += t["engagement"]
        by_type[tp]["total_likes"] += t["likes"]
        by_type[tp]["total_replies"] += t["replies"]
        by_type[tp]["total_rts"] += t["retweets"]
        if by_type[tp]["best"] is None or t["engagement"] > by_type[tp]["best"]["engagement"]:
            by_type[tp]["best"] = t

    print("📊 POST PERFORMANCE BY TYPE")
    print("=" * 50)
    for tp, data in sorted(by_type.items(), key=lambda x: x[1]["total_engagement"], reverse=True):
        avg = data["total_engagement"] / data["count"] if data["count"] > 0 else 0
        print(f"\n  {tp.upper()} ({data['count']} posts)")
        print(f"  Avg engagement: {avg:.1f} | Total: ♥{data['total_likes']} 🔁{data['total_rts']} 💬{data['total_replies']}")
        if data["best"]:
            preview = data["best"]["text"][:100] + "..." if len(data["best"]["text"]) > 100 else data["best"]["text"]
            print(f"  Best: {preview}")

    # Save tracking data
    tracker = load_json(GROWTH_FILE, {"snapshots": []})
    tracker["snapshots"].append({
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "by_type": {k: {kk: vv for kk, vv in v.items() if kk != "best"} for k, v in by_type.items()},
        "total_posts": len(tweets),
        "total_engagement": sum(t["engagement"] for t in tweets),
    })
    # Keep last 30 snapshots
    tracker["snapshots"] = tracker["snapshots"][-30:]
    save_json(GROWTH_FILE, tracker)

    return by_type

def growth_report():
    """Full growth report."""
    print("📈 X GROWTH REPORT — @YourHandle")
    print(f"   {datetime.now().strftime('%Y-%m-%d %H:%M ET')}")
    print("=" * 50)

    # Current metrics
    output = run_cmd(["xanalytics", "snapshot"])
    print(f"\n{output}")

    # Performance by type
    by_type = track_performance()

    # What's working / not working
    if by_type:
        print("\n\n🟢 WHAT'S WORKING:")
        sorted_types = sorted(by_type.items(), key=lambda x: x[1]["total_engagement"] / max(x[1]["count"], 1), reverse=True)
        for tp, data in sorted_types[:3]:
            avg = data["total_engagement"] / data["count"] if data["count"] > 0 else 0
            if avg > 0:
                print(f"  • {tp}: {avg:.1f} avg engagement per post")

        print("\n🔴 WHAT'S NOT WORKING:")
        for tp, data in sorted_types[-2:]:
            avg = data["total_engagement"] / data["count"] if data["count"] > 0 else 0
            print(f"  • {tp}: {avg:.1f} avg engagement per post")

    # Strategy history
    strategies = load_json(STRATEGY_FILE, {"strategies": []})
    if strategies.get("strategies"):
        print(f"\n\n📋 STRATEGY LOG ({len(strategies['strategies'])} entries):")
        for s in strategies["strategies"][-5:]:
            status = "✅" if s.get("result") else "⏳"
            print(f"  {status} [{s['date']}] {s['name']}")
            if s.get("result"):
                print(f"     Result: {s['result']}")

    # Recommendations
    print("\n\n🎯 RECOMMENDATIONS:")
    if by_type:
        best_type = sorted_types[0][0] if sorted_types else "general"
        print(f"  1. Double down on '{best_type}' posts — highest avg engagement")
        worst_type = sorted_types[-1][0] if sorted_types else "general"
        print(f"  2. Reduce or rework '{worst_type}' posts — lowest performance")
    print(f"  3. Reply to every comment within 30 min (algorithm boost)")
    print(f"  4. Post during peak hours: 8-10am, 12-1pm, 5-7pm ET")

def show_strategy():
    """Show current strategy and history."""
    strategies = load_json(STRATEGY_FILE, {"strategies": []})

    print("📋 STRATEGY LOG")
    print("=" * 50)

    if not strategies.get("strategies"):
        print("No strategies logged yet.")
        print("Run 'xgrowth new-strategy' to add the first one.")
        return

    for s in strategies["strategies"]:
        status = "✅" if s.get("result") else "⏳ Active"
        print(f"\n[{s['date']}] {s['name']} — {status}")
        print(f"  What: {s['description']}")
        if s.get("result"):
            print(f"  Result: {s['result']}")
        if s.get("metrics_before"):
            print(f"  Before: {s['metrics_before']}")
        if s.get("metrics_after"):
            print(f"  After: {s['metrics_after']}")

def log_strategy(name, description, metrics_before=""):
    """Log a new strategy."""
    strategies = load_json(STRATEGY_FILE, {"strategies": []})
    strategies["strategies"].append({
        "date": datetime.now().strftime("%Y-%m-%d"),
        "name": name,
        "description": description,
        "metrics_before": metrics_before,
        "metrics_after": "",
        "result": "",
    })
    save_json(STRATEGY_FILE, strategies)
    print(f"✅ Strategy logged: {name}")

def show_leaderboard():
    """Show accounts we should study."""
    accounts = [
        {"handle": "felixcraftai", "why": "AI CEO playbook, $80K revenue, 15K followers"},
        {"handle": "nateliason", "why": "Felix creator, build-in-public thought leader"},
        {"handle": "shaborswap", "why": "Copy trading tutorials, high repost rate"},
        {"handle": "CarOnPolymarket", "why": "Polymarket alpha, viral prediction market content"},
        {"handle": "perptools", "why": "AI agent trading, massive RT counts"},
        {"handle": "Bankless", "why": "Crypto media, podcast distribution power"},
    ]

    print("🏆 ACCOUNTS TO STUDY & EMULATE")
    print("=" * 50)
    for a in accounts:
        info = run_cmd(["xpost", "user", a["handle"]])
        followers = ""
        for line in info.split("\n"):
            if "Followers:" in line:
                followers = line.strip()
                break
        print(f"\n  @{a['handle']}")
        print(f"  Why: {a['why']}")
        if followers:
            print(f"  {followers}")

def main():
    args = sys.argv[1:]
    if not args or args[0] in {"-h", "--help"}:
        print_help()
        return

    cmd = args[0]

    if cmd == "track":
        track_performance()
    elif cmd == "report":
        growth_report()
    elif cmd == "strategy":
        show_strategy()
    elif cmd == "log-strategy":
        if len(args) < 3:
            print("Usage: xgrowth log-strategy \"name\" \"description\"", file=sys.stderr)
            sys.exit(1)
        log_strategy(args[1], args[2], args[3] if len(args) > 3 else "")
    elif cmd == "leaderboard":
        show_leaderboard()
    elif cmd == "new-strategy":
        print("🧪 TODAY'S NEW STRATEGY PROPOSAL")
        print("=" * 50)
        print()
        print("Run 'xgrowth track' first to see what's working,")
        print("then 'xgrowth log-strategy \"name\" \"description\"' to log it.")
        print()
        print("Strategy ideas based on current data:")
        print("  1. Thread hooks — start threads with a bold claim + promise")
        print("  2. Data screenshots — visual content gets 2-3x engagement")
        print("  3. Quote-tweet viral content with our angle")
        print("  4. Post at peak hours only (8-10am, 12-1pm, 5-7pm ET)")
        print("  5. End every post with a question to drive replies")
        print("  6. Tag relevant accounts in value posts (not spam)")
        print("  7. Create a recurring series (Daily Alpha, Weekly P&L)")
        print("  8. Engage in 5+ conversations daily on others' posts")
    else:
        print(f"Unknown command: {cmd}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
