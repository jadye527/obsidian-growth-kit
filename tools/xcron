def print_help() -> None:
    """Print the CLI help text."""
    print(HELP_TEXT)


def exit_error(message: str) -> None:
    """Print an actionable error message and exit with status 1."""
    print(message, file=sys.stderr)
    raise SystemExit(1)


def parse_args(args: list[str]) -> dict[str, object]:
    """Parse and validate top-level CLI arguments."""
    options: dict[str, object] = {"dry_run": False, "command_args": []}
    command: str | None = None
    command_args: list[str] = []

    for arg in args:
        if command is None:
            if arg == "--dry-run":
                options["dry_run"] = True
                continue
            if arg in {"-h", "--help"}:
                options["help"] = True
                continue
            if arg.startswith("--"):
                exit_error(f"Unknown option: {arg}")
            command = arg
            continue

        if arg == "--dry-run":
            options["dry_run"] = True
            continue
        command_args.append(arg)

    if options.get("help"):
        return options

    if command is None:
        return {"help": True}

    options["command"] = command
    options["command_args"] = command_args
    return options


def parse_install_schedule_args(args: list[str]) -> dict[str, str]:
    """Parse and validate install-schedule options."""
    options = {"scheduler": "auto"}
    index = 0

    while index < len(args):
        token = args[index]
        if token == "--scheduler":
            if index + 1 >= len(args):
                exit_error("Missing value for --scheduler")
            scheduler = args[index + 1]
            if scheduler not in {"auto", "systemd", "crontab"}:
                exit_error("--scheduler must be one of: auto, systemd, crontab")
            options["scheduler"] = scheduler
            index += 2
            continue
        exit_error(f"Unknown option: {token}")

    return options


def run_command(args: list[str], dry_run: bool = False) -> str:
    """Run a subprocess command and return stdout."""
    command_text = " ".join(args)
    print(f"$ {command_text}")
    if dry_run:
        return ""

    result = subprocess.run(args, capture_output=True, text=True, check=False)
    if result.returncode != 0:
        details = result.stderr.strip() or result.stdout.strip() or "command failed"
        exit_error(f"{command_text}: {details}")

    output = result.stdout.strip()
    if output:
        print(output)
    return output


def run_system_command(
    args: list[str],
    *,
    dry_run: bool = False,
    input_text: str | None = None,
) -> subprocess.CompletedProcess[str]:
    """Run a subprocess command used for scheduler installation."""
    command_text = " ".join(shlex.quote(arg) for arg in args)
    print(f"$ {command_text}")

    if dry_run:
        return subprocess.CompletedProcess(args, 0, "", "")

    return subprocess.run(
        args,
        input=input_text,
        capture_output=True,
        text=True,
        check=False,
    )


def ensure_directory(path: str, dry_run: bool = False) -> None:
    """Create a directory unless dry-run mode is enabled."""
    if dry_run:
        print(f"$ mkdir -p {shlex.quote(path)}")
        return
    os.makedirs(path, exist_ok=True)


def write_text_file(path: str, contents: str, dry_run: bool = False) -> None:
    """Write UTF-8 text to disk unless dry-run mode is enabled."""
    if dry_run:
        print(f"$ write {path}")
        print(contents.rstrip())
        return

    with open(path, "w", encoding="utf-8") as file_handle:
        file_handle.write(contents)


