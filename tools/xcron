def build_schedule_command(command: str) -> str:
    """Build a scheduled autonomous job command with explicit environment."""
    path_value = f'{BIN_DIR}:/usr/local/bin:/usr/bin:/bin'
    env_bits = [
        f"PATH={shlex.quote(path_value)}",
        f"X_QUEUE_FILE={shlex.quote(QUEUE_FILE)}",
        f"X_KEYS_FILE={shlex.quote(KEYS_FILE)}",
    ]
    return " ".join(env_bits) + f" {command} >/dev/null 2>&1"


def remove_managed_cron_block(crontab_text: str) -> str:
    """Remove the managed Obsidian Growth Kit block from a crontab."""
    kept_lines: list[str] = []
    skip = False

    for line in crontab_text.splitlines():
        if line == CRON_BLOCK_START:
            skip = True
            continue
        if line == CRON_BLOCK_END:
            skip = False
            continue
        if not skip:
            kept_lines.append(line)

    return "\n".join(kept_lines).strip("\n")


def build_crontab_text(existing_crontab: str) -> str:
    """Merge the managed schedule block into an existing crontab."""
    preserved = remove_managed_cron_block(existing_crontab)
    lines: list[str] = []

    if preserved:
        lines.append(preserved)
    lines.append(CRON_BLOCK_START)
    lines.append("CRON_TZ=America/New_York")
    for job in build_job_specs():
        lines.append(
            f'{job["cron_expr"]} {build_schedule_command(job["command"])}'
        )
    lines.append(CRON_BLOCK_END)
    return "\n".join(lines) + "\n"


def install_crontab_schedule(dry_run: bool = False) -> None:
    """Install the managed schedule into the user's crontab."""
    result = run_system_command(["crontab", "-l"], dry_run=dry_run)
    current_crontab = result.stdout if result.returncode == 0 else ""
    new_crontab = build_crontab_text(current_crontab)

    if dry_run:
        print(new_crontab.rstrip())
        print("crontab installed for autonomous X growth workflows")
        return

    install_result = run_system_command(
        ["crontab", "-"],
        input_text=new_crontab,
    )
    if install_result.returncode != 0:
        details = install_result.stderr.strip() or "crontab installation failed"
        exit_error(details)

    print("crontab installed for autonomous X growth workflows")


def build_systemd_service_text(command: str) -> str:
    """Build the systemd service definition for an autonomous job."""
    path_value = shlex.quote(f"{BIN_DIR}:/usr/local/bin:/usr/bin:/bin")
    queue_value = shlex.quote(QUEUE_FILE)
    keys_value = shlex.quote(KEYS_FILE)
    exec_start = (
        "/bin/sh -lc "
        f"'PATH={path_value}; export PATH "
        f"X_QUEUE_FILE={queue_value} "
        f"X_KEYS_FILE={keys_value}; exec {command}'"
    )
    return f"""[Unit]
Description=Obsidian Growth Kit autonomous workflow

[Service]
Type=oneshot
ExecStart={exec_start}
"""


def build_systemd_timer_text(job_name: str, on_calendar: str) -> str:
    """Build the systemd timer definition for an autonomous job."""
    unit_name = f"{SCHEDULER_PREFIX}-{job_name}.service"
    return f"""[Unit]
Description=Obsidian Growth Kit autonomous workflow timer

[Timer]
OnCalendar={on_calendar}
Persistent=true
Unit={unit_name}

[Install]
WantedBy=timers.target
"""


def enable_systemd_linger(dry_run: bool = False) -> bool:
    """Enable user lingering so user timers survive reboots."""
    if not SYSTEMD_LINGER_USER:
        print("Unable to determine linger user. Timer may require login after reboot.")
        return False
    if shutil.which("loginctl") is None:
        print("loginctl not found. User timer may require login after reboot.")
        return False

    result = run_system_command(
        ["loginctl", "enable-linger", SYSTEMD_LINGER_USER],
        dry_run=dry_run,
    )
    if result.returncode == 0:
        print("user lingering enabled for reboot persistence")
        return True

    print(
        f"Unable to enable lingering for {SYSTEMD_LINGER_USER}. "
        "Timer may require login after reboot."
    )
    return False


def install_systemd_timer(dry_run: bool = False) -> bool:
    """Install the managed systemd user timer."""
    if shutil.which("systemctl") is None:
        return False
    if not enable_systemd_linger(dry_run=dry_run):
        return False

    ensure_directory(SYSTEMD_USER_DIR, dry_run=dry_run)
    for job in build_job_specs():
        job_name = f'{SCHEDULER_PREFIX}-{job["name"]}'
        service_file = os.path.join(SYSTEMD_USER_DIR, f"{job_name}.service")
        timer_file = os.path.join(SYSTEMD_USER_DIR, f"{job_name}.timer")
        write_text_file(
            service_file,
            build_systemd_service_text(job["command"]),
            dry_run=dry_run,
        )
        write_text_file(
            timer_file,
            build_systemd_timer_text(job["name"], job["on_calendar"]),
            dry_run=dry_run,
        )

    daemon_reload = run_system_command(
        ["systemctl", "--user", "daemon-reload"],
        dry_run=dry_run,
    )
    if daemon_reload.returncode != 0:
        return False

    for job in build_job_specs():
        enable_result = run_system_command(
            [
                "systemctl",
                "--user",
                "enable",
                "--now",
                f'{SCHEDULER_PREFIX}-{job["name"]}.timer',
            ],
            dry_run=dry_run,
        )
        if enable_result.returncode != 0:
            return False

    print("systemd timers installed for autonomous X growth workflows")
    return True


def install_schedule(command_args: list[str], dry_run: bool = False) -> None:
    """Install persistent autonomous workflows using systemd or crontab."""
    options = parse_install_schedule_args(command_args)
    scheduler = options["scheduler"]

    if scheduler in {"auto", "systemd"} and install_systemd_timer(dry_run=dry_run):
        return

    if scheduler == "systemd":
        exit_error("systemd timer setup failed")

    if scheduler in {"auto", "crontab"}:
        if shutil.which("crontab") is None:
            exit_error("crontab is not available")
        install_crontab_schedule(dry_run=dry_run)
        return

    exit_error(f"Unknown scheduler: {scheduler}")


def load_scout_results() -> list[dict[str, object]]:
    """Load previously scanned scout results from disk."""
    if not os.path.exists(SCOUT_RESULTS_FILE):
        return []

    with open(SCOUT_RESULTS_FILE, encoding="utf-8") as file_handle:
        data = json.load(file_handle)

    results = data.get("results", [])
    if isinstance(results, list):
        return [item for item in results if isinstance(item, dict)]
    return []


def get_queue_count(dry_run: bool = False) -> int:
    """Return the number of queued posts."""
    output = run_command(["xqueue", "count"], dry_run=dry_run)
    if dry_run or not output:
        return 0

    try:
        return int(output)
    except ValueError as exc:
        exit_error(f"Unable to parse queue size from xqueue count: {output!r}")
        raise AssertionError from exc


def truncate_text(text: str, limit: int = MAX_POST_LENGTH) -> str:
    """Trim text to the provided character limit."""
    if len(text) <= limit:
        return text
    return text[: limit - 3].rstrip() + "..."


def normalize_text(text: str) -> str:
    """Collapse tweet text into a single, compact line."""
    parts = text.replace("\n", " ").split()
    return " ".join(parts)


def build_reactive_post(tweet: dict[str, object], slot: int) -> str:
    """Build a short queued post from a scout result."""
    topic = str(tweet.get("topic") or "this niche").replace("-", " ")
    source_text = normalize_text(str(tweet.get("text") or ""))
    snippet = truncate_text(source_text, limit=110)

    templates = [
        (
            f"{topic.title()} signal worth watching today:\n\n"
            f"{snippet}\n\n"
            "My take: the edge usually goes to whoever ships while the "
            "topic is still moving."
        ),
        (
            f"One thing I keep noticing in {topic}:\n\n"
            f"{snippet}\n\n"
            "If you're building here, speed of iteration still beats "
            "perfect positioning."
        ),
        (
            f"{topic.title()} is getting louder again.\n\n"
            f"{snippet}\n\n"
            "The useful question is what changes in behavior, not just what trends."
        ),
    ]
    return truncate_text(templates[slot % len(templates)])


def queue_reactive_posts(target_count: int, dry_run: bool = False) -> int:
    """Queue enough posts to reach the requested target queue size."""
    queue_count = get_queue_count(dry_run=dry_run)
    needed = max(0, target_count - queue_count)

    if needed == 0:
        print(f"Queue already has {queue_count} post(s); target is {target_count}.")
        return 0

    results = load_scout_results()
    if not results:
        print("No scout results available for queue generation.")
        return 0

    added = 0
    used_ids: set[str] = set()
    for tweet in results:
        tweet_id = str(tweet.get("id") or "")
        if tweet_id and tweet_id in used_ids:
            continue
        if tweet_id:
            used_ids.add(tweet_id)

        post_text = build_reactive_post(tweet, added)
        run_command(["xqueue", "add", post_text], dry_run=dry_run)
        added += 1

        if added >= needed:
            break

    print(f"Queued {added} new post(s).")
    return added


def like_top_scout_results(
    *, min_likes: int, limit: int, dry_run: bool = False
) -> int:
    """Like the highest-engagement scout results up to the provided limit."""
    results = load_scout_results()
    liked = 0

    for tweet in results:
        tweet_id = str(tweet.get("id") or "")
        likes = int(tweet.get("likes") or 0)
        if not tweet_id.isdigit() or likes < min_likes:
            continue

        run_command(["xpost", "like", tweet_id], dry_run=dry_run)
        liked += 1
        if liked >= limit:
            break

    print(f"Liked {liked} high-signal post(s).")
    return liked


def parse_publish_meme_post_args(args: list[str]) -> dict[str, object]:
    """Parse and validate publish-meme-post options."""
    options: dict[str, object] = {
        "bottom_text": "",
        "generator": "",
        "python": "",
        "mentions_limit": 10,
    }
    index = 0

    while index < len(args):
        token = args[index]
        if token in {
            "--template",
            "--top-text",
            "--bottom-text",
            "--output-dir",
            "--generator",
            "--python",
            "--text-file",
            "--self-reply-file",
            "--mention-reply-file",
        }:
            if index + 1 >= len(args):
                exit_error(f"Missing value for {token}")
            options[token[2:].replace("-", "_")] = args[index + 1]
            index += 2
            continue
        if token == "--mentions-limit":
            if index + 1 >= len(args):
                exit_error(f"Missing value for {token}")
            limit_text = args[index + 1]
            if not limit_text.isdigit() or int(limit_text) <= 0:
                exit_error("--mentions-limit must be a positive integer")
            options["mentions_limit"] = int(limit_text)
            index += 2
            continue
        exit_error(f"Unknown option: {token}")

    required = [
        "template",
        "top_text",
        "output_dir",
        "text_file",
        "self_reply_file",
        "mention_reply_file",
    ]
    missing = [name for name in required if not options.get(name)]
    if missing:
        exit_error(
            "Usage: xcron publish-meme-post --template <name> --top-text <text> "
            "[--bottom-text <text>] --output-dir <dir> [--generator <path>] "
            "[--python <path>] --text-file <path> --self-reply-file <path> "
            "--mention-reply-file <path> [--mentions-limit <number>]"
        )

    return options


def load_text_file(path: str) -> str:
    """Read UTF-8 text from a file path."""
    expanded_path = os.path.expanduser(path)
    try:
        with open(expanded_path, encoding="utf-8") as file_handle:
            return file_handle.read().strip()
    except OSError as exc:
        exit_error(f"Unable to read text file {expanded_path}: {exc}")
        raise AssertionError from exc


def extract_tweet_id(output: str) -> str:
    """Extract a tweet ID from xpost output."""
    match = re.search(r"/status/(\d+)", output)
    if match:
        return match.group(1)
    match = re.search(r"id:(\d+)", output)
    if match:
        return match.group(1)
    exit_error(f"Unable to find tweet ID in xpost output: {output!r}")
    raise AssertionError


def extract_mention_ids(output: str) -> list[str]:
    """Parse mention tweet IDs from xpost mentions output."""
    ids: list[str] = []
    seen: set[str] = set()

    for line in output.splitlines():
        match = re.search(r"id:(\d+)", line)
        if not match:
            continue
        tweet_id = match.group(1)
        if tweet_id in seen:
            continue
        seen.add(tweet_id)
        ids.append(tweet_id)

    return ids


def build_meme_command(options: dict[str, object]) -> list[str]:
    """Build the xmeme generate command from parsed options."""
    command = [
        "xmeme",
        "generate",
        "--template",
        str(options["template"]),
        "--top-text",
        str(options["top_text"]),
        "--output-dir",
        str(options["output_dir"]),
    ]

    if options.get("bottom_text"):
        command.extend(["--bottom-text", str(options["bottom_text"])])
    if options.get("generator"):
        command.extend(["--generator", str(options["generator"])])
    if options.get("python"):
        command.extend(["--python", str(options["python"])])

    return command


def run_publish_meme_post(command_args: list[str], dry_run: bool = False) -> None:
    """Run the meme publish pipeline from content generation through replies."""
    options = parse_publish_meme_post_args(command_args)
    meme_path = run_command(build_meme_command(options), dry_run=dry_run)
    if dry_run:
        meme_path = "<generated-meme>"

    post_output = run_command(
        [
            "xpost",
            "--text-file",
            os.path.expanduser(str(options["text_file"])),
            "--media",
            meme_path,
        ],
        dry_run=dry_run,
    )
    if dry_run:
        return

    post_id = extract_tweet_id(post_output)
    self_reply_text = load_text_file(str(options["self_reply_file"]))
    run_command(["xpost", "reply", post_id, self_reply_text], dry_run=dry_run)

    mention_reply_text = load_text_file(str(options["mention_reply_file"]))
    mentions_output = run_command(["xpost", "mentions"], dry_run=dry_run)
    mention_ids = extract_mention_ids(mentions_output)

    for mention_id in mention_ids[: int(options["mentions_limit"])]:
        run_command(
            ["xpost", "reply", mention_id, mention_reply_text],
            dry_run=dry_run,
        )


def get_autonomous_post_env() -> dict[str, object]:
    """Load publish-meme-post options from environment variables."""
    options: dict[str, object] = {
        "template": os.environ.get("X_AUTONOMOUS_POST_TEMPLATE", ""),
        "top_text": os.environ.get("X_AUTONOMOUS_POST_TOP_TEXT", ""),
        "bottom_text": os.environ.get("X_AUTONOMOUS_POST_BOTTOM_TEXT", ""),
        "output_dir": os.environ.get(
            "X_AUTONOMOUS_POST_OUTPUT_DIR",
            os.path.join(os.path.expanduser("~"), "obsidian-growth-kit", "out"),
        ),
        "text_file": os.environ.get("X_AUTONOMOUS_POST_TEXT_FILE", ""),
        "self_reply_file": os.environ.get(
            "X_AUTONOMOUS_POST_SELF_REPLY_FILE", ""
        ),
        "mention_reply_file": os.environ.get(
            "X_AUTONOMOUS_POST_MENTION_REPLY_FILE", ""
        ),
        "mentions_limit": os.environ.get(
            "X_AUTONOMOUS_POST_MENTIONS_LIMIT", "10"
        ),
    }

    mentions_limit_text = str(options["mentions_limit"])
    if not mentions_limit_text.isdigit() or int(mentions_limit_text) <= 0:
        exit_error(
            "X_AUTONOMOUS_POST_MENTIONS_LIMIT must be a positive integer"
        )

    required = [
        "template",
        "top_text",
        "text_file",
        "self_reply_file",
        "mention_reply_file",
    ]
    missing = [name for name in required if not options[name]]
    if missing:
        env_names = ", ".join(
            [
                "X_AUTONOMOUS_POST_TEMPLATE",
                "X_AUTONOMOUS_POST_TOP_TEXT",
                "X_AUTONOMOUS_POST_TEXT_FILE",
                "X_AUTONOMOUS_POST_SELF_REPLY_FILE",
                "X_AUTONOMOUS_POST_MENTION_REPLY_FILE",
            ]
        )
        exit_error(
            "autonomous-post requires configured environment variables: "
            f"{env_names}"
        )

    return options


def build_publish_args_from_options(options: dict[str, object]) -> list[str]:
    """Convert publish options into publish-meme-post CLI args."""
    command_args = [
        "--template",
        str(options["template"]),
        "--top-text",
        str(options["top_text"]),
        "--output-dir",
        str(options["output_dir"]),
        "--text-file",
        str(options["text_file"]),
        "--self-reply-file",
        str(options["self_reply_file"]),
        "--mention-reply-file",
        str(options["mention_reply_file"]),
        "--mentions-limit",
        str(options["mentions_limit"]),
    ]
    if options.get("bottom_text"):
        command_args.extend(["--bottom-text", str(options["bottom_text"])])
    return command_args


def run_autonomous_post(dry_run: bool = False) -> None:
    """Run the scheduled posting pipeline from environment-backed settings."""
    options = get_autonomous_post_env()
    run_publish_meme_post(
        build_publish_args_from_options(options),
        dry_run=dry_run,
    )


def run_morning_growth(dry_run: bool = False) -> None:
    """Run the daily morning growth pipeline."""
    run_command(["xanalytics", "snapshot"], dry_run=dry_run)
    run_command(["xanalytics", "compare"], dry_run=dry_run)
    run_command(["xscout", "scan"], dry_run=dry_run)
    run_command(["xgrowth", "track"], dry_run=dry_run)
    run_command(["xgrowth", "new-strategy"], dry_run=dry_run)
    queue_reactive_posts(target_count=5, dry_run=dry_run)


def run_content_scout(dry_run: bool = False) -> None:
    """Run the scouting and engagement pipeline."""
    run_command(["xscout", "report"], dry_run=dry_run)
    like_top_scout_results(min_likes=50, limit=3, dry_run=dry_run)
    queue_reactive_posts(target_count=3, dry_run=dry_run)


def run_nightly_review(dry_run: bool = False) -> None:
    """Run the nightly review and queue refresh pipeline."""
    run_command(["xgrowth", "report"], dry_run=dry_run)
    run_command(["xanalytics", "compare"], dry_run=dry_run)
    run_command(["xscout", "scan"], dry_run=dry_run)
    queue_reactive_posts(target_count=3, dry_run=dry_run)


def run_analytics_snapshot(dry_run: bool = False) -> None:
    """Capture an analytics snapshot."""
    run_command(["xanalytics", "snapshot"], dry_run=dry_run)


def main() -> None:
    """Run the xcron command-line interface."""
    options = parse_args(sys.argv[1:])
    if options.get("help"):
        print_help()
        return

    command = str(options["command"])
    command_args = list(options["command_args"])
    dry_run = bool(options["dry_run"])

    if command == "install-schedule":
        install_schedule(command_args, dry_run=dry_run)
        return
    if command == "autonomous-post":
        if command_args:
            exit_error("Usage: xcron autonomous-post [--dry-run]")
        run_autonomous_post(dry_run=dry_run)
        return
    if command == "morning-growth":
        if command_args:
            exit_error("Usage: xcron morning-growth [--dry-run]")
        run_morning_growth(dry_run=dry_run)
        return
    if command == "content-scout":
        if command_args:
            exit_error("Usage: xcron content-scout [--dry-run]")
        run_content_scout(dry_run=dry_run)
        return
    if command == "nightly-review":
        if command_args:
            exit_error("Usage: xcron nightly-review [--dry-run]")
        run_nightly_review(dry_run=dry_run)
        return
    if command == "analytics-snapshot":
        if command_args:
            exit_error("Usage: xcron analytics-snapshot [--dry-run]")
        run_analytics_snapshot(dry_run=dry_run)
        return
    if command == "publish-meme-post":
        run_publish_meme_post(command_args, dry_run=dry_run)
        return

    exit_error(f"Unknown command: {command}")


if __name__ == "__main__":
    main()
