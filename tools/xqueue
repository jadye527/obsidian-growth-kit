#!/usr/bin/env python3
"""xqueue — Tweet scheduler.
Queues tweets and posts them at intervals to avoid spam filters.
"""
import json
import os
import subprocess
import sys
import time

QUEUE_FILE = os.environ.get("X_QUEUE_FILE", os.path.expanduser("~/.config/x-api/queue.json"))
MIN_INTERVAL = 900  # 15 minutes between tweets (safe for new accounts)


HELP_TEXT = """xqueue — Tweet Scheduler

Usage:
  xqueue <command> [args]
  xqueue --help

Commands:
  add "tweet text"          Add tweet to queue
  list                      Show queued tweets
  flush                     Post all queued tweets with cooldown delays
  next                      Post the next queued tweet if cooldown passed
  clear                     Clear the queue
  count                     Show queue size

Examples:
  xqueue add "Shipping one useful change at a time"
  xqueue list
  xqueue next
  xqueue flush
"""


def print_help():
    print(HELP_TEXT)


class QueueError(Exception):
    """Raised when queue data cannot be loaded or saved."""


def exit_error(message):
    """Print an actionable error message and exit."""
    print(message, file=sys.stderr)
    raise SystemExit(1)


def load_queue():
    if os.path.exists(QUEUE_FILE):
        try:
            with open(QUEUE_FILE) as f:
                return json.load(f)
        except OSError as exc:
            raise QueueError(f"Unable to read queue file {QUEUE_FILE}: {exc}") from exc
        except json.JSONDecodeError as exc:
            raise QueueError(
                f"Queue file is not valid JSON: {QUEUE_FILE}: {exc}"
            ) from exc
    return {"tweets": [], "last_posted": 0}


def save_queue(q):
    try:
        os.makedirs(os.path.dirname(QUEUE_FILE), exist_ok=True)
        with open(QUEUE_FILE, "w") as f:
            json.dump(q, f, indent=2)
    except OSError as exc:
        raise QueueError(f"Unable to write queue file {QUEUE_FILE}: {exc}") from exc


def main():
    args = sys.argv[1:]
    if not args or args[0] in {"-h", "--help"}:
        print_help()
        return

    cmd = args[0]
    try:
        q = load_queue()
    except QueueError as exc:
        exit_error(f"Queue error: {exc}")

    if cmd == "add":
        text = args[1] if len(args) > 1 else None
        if not text:
            exit_error("Usage: xqueue add \"tweet text\"")
        q["tweets"].append({"text": text, "added": int(time.time())})
        try:
            save_queue(q)
        except QueueError as exc:
            exit_error(f"Queue error: {exc}")
        print(f"Queued. ({len(q['tweets'])} in queue)")

    elif cmd == "list":
        if not q["tweets"]:
            print("Queue empty.")
        else:
            for i, t in enumerate(q["tweets"]):
                preview = t["text"][:80].replace("\n", " ")
                print(f"  {i+1}. {preview}...")

    elif cmd == "count":
        print(len(q["tweets"]))

    elif cmd == "clear":
        q["tweets"] = []
        try:
            save_queue(q)
        except QueueError as exc:
            exit_error(f"Queue error: {exc}")
        print("Queue cleared.")

    elif cmd == "next":
        if not q["tweets"]:
            print("Queue empty.")
            return
        elapsed = int(time.time()) - q.get("last_posted", 0)
        if elapsed < MIN_INTERVAL:
            remaining = MIN_INTERVAL - elapsed
            print(f"Cooldown: {remaining}s remaining")
            return
        tweet = q["tweets"].pop(0)
        try:
            result = subprocess.run(
                ["xpost", "tweet", tweet["text"]],
                capture_output=True, text=True, timeout=30
            )
            if result.returncode == 0:
                q["last_posted"] = int(time.time())
                try:
                    save_queue(q)
                except QueueError as exc:
                    q["tweets"].insert(0, tweet)
                    exit_error(f"Queue error: {exc}")
                print(result.stdout.strip())
            else:
                # Put it back if it failed
                q["tweets"].insert(0, tweet)
                try:
                    save_queue(q)
                except QueueError as exc:
                    exit_error(f"Queue error: {exc}")
                exit_error(f"Failed: {result.stderr.strip()}")
        except Exception as e:
            q["tweets"].insert(0, tweet)
            try:
                save_queue(q)
            except QueueError as exc:
                exit_error(f"Queue error: {exc}")
            exit_error(f"Error: {e}")

    elif cmd == "flush":
        if not q["tweets"]:
            print("Queue empty.")
            return
        count = len(q["tweets"])
        print(f"Flushing {count} tweets (15-min intervals)...")
        posted = 0
        while q["tweets"]:
            elapsed = int(time.time()) - q.get("last_posted", 0)
            if elapsed < MIN_INTERVAL:
                wait = MIN_INTERVAL - elapsed
                print(f"  Waiting {wait}s...")
                time.sleep(wait)
            tweet = q["tweets"].pop(0)
            try:
                result = subprocess.run(
                    ["xpost", "tweet", tweet["text"]],
                    capture_output=True, text=True, timeout=30
                )
                if result.returncode == 0:
                    q["last_posted"] = int(time.time())
                    try:
                        save_queue(q)
                    except QueueError as exc:
                        q["tweets"].insert(0, tweet)
                        exit_error(f"Queue error: {exc}")
                    posted += 1
                    print(f"  [{posted}/{count}] {result.stdout.strip()}")
                else:
                    q["tweets"].insert(0, tweet)
                    try:
                        save_queue(q)
                    except QueueError as exc:
                        exit_error(f"Queue error: {exc}")
                    print(f"  Failed — retrying after longer cooldown")
                    time.sleep(MIN_INTERVAL)
            except Exception as e:
                q["tweets"].insert(0, tweet)
                try:
                    save_queue(q)
                except QueueError as exc:
                    exit_error(f"Queue error: {exc}")
                print(f"  Error: {e}")
                break
        print(f"Done. Posted {posted}/{count}.")

    else:
        exit_error(f"Unknown command: {cmd}")

if __name__ == "__main__":
    main()
